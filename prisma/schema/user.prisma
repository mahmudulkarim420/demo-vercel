model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CUSTOMER)
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  technicianProfile TechnicianProfile?
  bookings          Booking[]
  reviews           Review[]

  @@index([status])
}
